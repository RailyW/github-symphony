{
  "name": "github-symphony-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop dashboard for the GitHub Projects v2 Codex orchestrator.",
  "author": "GitHub Symphony Contributors",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && tsc -p tsconfig.electron.json && electron dist-electron/main.js",
    "build": "tsc -p tsconfig.json && vite build && tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "dev.github-symphony.desktop",
    "productName": "GitHub Symphony",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/symphony-github-backend",
        "to": "backend/symphony-github-backend"
      },
      {
        "from": "../WORKFLOW.example.md",
        "to": "WORKFLOW.example.md"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
